<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/info_title_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="Name"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/info_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="info_name"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/info_title_size"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="Size"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/info_size"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="info_size"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/info_title_typesandnumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="TypesAndNumber"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/info_typesandnumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="info_typesandnumber"
        android:textSize="20sp"
        android:textStyle="bold" />
</LinearLayout>